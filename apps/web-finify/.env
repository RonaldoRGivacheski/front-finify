# Application Title
VITE_APP_TITLE=Finify

# Application namespaces are prefixes used for functions such as caching and stores to ensure isolation.
VITE_APP_NAMESPACE=app-finify

# The key used to encrypt the store will be used for encryption when the store is persisted to localStorage.
VITE_APP_STORE_SECURE_KEY=please-replace-me-with-your-own-key
