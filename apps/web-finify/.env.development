# port number
VITE_PORT=5666

VITE_BASE=/

# Interface address
VITE_GLOB_API_URL=http://localhost:8000/api/v1/

# Enable or disable Nitro Mock service. `true` means enabled, `false` means disabled.
VITE_NITRO_MOCK=false

# Enables or disables devtools; true for enabled, false for disabled.
VITE_DEVTOOLS=false

# Inject global loading indicator?
VITE_INJECT_APP_LOADING=true
